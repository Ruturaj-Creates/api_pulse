# Copy this file to .env and fill in your values:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Mac/Linux)

# Application
APP_NAME=API Pulse
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://pulse_user:pulse_password@localhost:5432/api_pulse

# JWT (change SECRET_KEY in production!)
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Monitoring
DEFAULT_CHECK_INTERVAL_SECONDS=60
FAILURE_THRESHOLD=3
HEALTH_CHECK_TIMEOUT_SECONDS=30
HEALTH_CHECK_MAX_RETRIES=1
SCHEDULER_TICK_SECONDS=30
MAX_CONCURRENT_CHECKS=20

# Email alerts (mock — configure later)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@apipulse.local
